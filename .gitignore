# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Virtualenvs
venv/
.venv/
env/
ENV/
venv.bak/

# IDEs and editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Logs and databases
*.log
*.sqlite3

# Compiled extensions
*.so
*.dylib

# ROS / colcon
install/
log/
.rosinstall

# Misc
*.pyc
*.pyo
*.pyd

# Markdown docs: keep README files tracked, ignore the rest
*.md
!README.md
!**/README.md
